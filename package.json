{
  "name": "polymarket-bloomberg-tui",
  "version": "1.0.0",
  "description": "Bloomberg-style TUI for monitoring Polymarket prediction markets",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bun run build:single",
    "build-mahari": "bun run build:single",
    "build:mahari": "bun run build:single",
    "build:single": "bun run script/build.ts --single",
    "build:baseline": "bun run script/build.ts --single --baseline",
    "build:all": "bun run script/build.ts",
    "release:upload:zip": "bun run script/build.ts --upload-zip",
    "type-check": "tsc --noEmit",
    "mcp": "bun run src/mcp/server.ts",
    "mcp:http": "bun run src/mcp/server.ts --port 3000",
    "telegram": "bun run src/telegram/bot.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "1.0.0",
    "@opentui/core": "^0.1.80",
    "@opentui/solid": "^0.1.80",
    "@types/three": "^0.183.1",
    "ai": "^4.0.0",
    "bun-webgpu": "^0.1.5",
    "graphql": "^16.9.0",
    "graphql-request": "7.4.0",
    "pmxtjs": "^2.18.1",
    "solid-js": "^1.9.3",
    "three": "^0.183.2",
    "viem": "^2.46.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/bun": "latest"
  },
  "engine": {
    "bun": ">=1.0.0"
  }
}
