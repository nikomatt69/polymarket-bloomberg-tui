{
  "name": "polymarket-bloomberg-tui",
  "version": "1.0.0",
  "description": "Bloomberg-style TUI for monitoring Polymarket prediction markets",
  "type": "module",
  "main": "src/index.tsx",
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run src/index.tsx",
    "build": "bun run build:mahari",
    "build-mahari": "bun run build:mahari",
    "build:mahari": "bun -e \"import solidPlugin from '@opentui/solid/bun-plugin'; const result = await Bun.build({ entrypoints: ['src/index.tsx'], outdir: 'dist', target: 'bun', plugins: [solidPlugin] }); if (!result.success) { for (const log of result.logs) console.error(log); process.exit(1); }\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "mcp": "bun run src/mcp/server.ts",
    "mcp:http": "bun run src/mcp/server.ts --port 3000",
    "telegram": "bun run src/telegram/bot.ts",
    "scheduler": "bun run src/automation/scheduler.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "1.0.0",
    "@opentui/core": "^0.1.80",
    "@opentui/solid": "^0.1.80",
    "ai": "^4.0.0",
    "graphql": "^16.9.0",
    "graphql-request": "7.4.0",
    "simple-ascii-chart": "^1.0.2",
    "solid-js": "^1.9.3",
    "viem": "^2.46.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/ui": "^4.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "engine": {
    "bun": ">=1.0.0"
  }
}
